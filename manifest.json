{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "Rastin",
  "version": "1.5.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",

  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": ["https://translate.googleapis.com/*"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/errors.js", "scripts/code-detection.js", "scripts/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["fonts/IRANYekanX/*", "fonts/Cartograph CF/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "__MSG_cmdOpenPopup__"
    },
    "toggle-rtl": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "__MSG_cmdToggleRtl__"
    },
    "translate-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "__MSG_cmdTranslate__"
    }
  },

  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
